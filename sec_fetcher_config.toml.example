# sec-fetcher configuration — copy this file to sec_fetcher_config.toml

# Required. SEC mandates a contact email in every User-Agent header.
#
# You have three options — pick whichever suits your workflow:
#   1. Uncomment the line below and fill in your address (persistent config).
#   2. Set the environment variable instead: SEC_FETCHER_EMAIL=you@example.com cargo run
#   3. Leave everything unset: if you run the binary in a terminal the program
#      will automatically ask you to type your email at startup before it does
#      anything else. Nothing to configure ahead of time.
# email = "your.name@example.com"

# The following are optional, to override defaults.

# Override the app name sent in the User-Agent header to the SEC.
# Defaults to "sec-fetcher" (the crate name). The SEC's User-Agent format is:
#   AppName/Version (+contact@email)
# Only change this if you are embedding sec-fetcher in a larger application and
# want the SEC to see your application's name instead.
# app_name = "my-app"
#
# The combination of max_concurrent * min_delay_ms should not exceed 10 requests per second
# as your requests may become rate-limited by the SEC. Defaults are extremely conservative.
#
# max_concurrent = 1
# min_delay_ms = 500
# max_retries = 3
# http_cache_storage_bin = "custom/path/to/cache.bin"
