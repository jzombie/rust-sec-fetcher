# Example configuration for sec-fetcher (copy to sec_fetcher_config.toml)
#
# ── Why is `email` required? ─────────────────────────────────────────────────
#
# The SEC requires all automated EDGAR data requests to include a descriptive
# User-Agent header containing a contact email address.  This allows the SEC
# to contact you if your client is causing problems with their servers.  See:
#   https://www.sec.gov/os/accessing-edgar-data
#
# Without a valid email address this library cannot construct a compliant
# User-Agent header and will refuse to make network requests.
#
# ── How to supply the email (precedence, highest → lowest) ───────────────────
#
#   1. This config file    → email = "your.name@example.com"  (below)
#   2. Environment variable → SEC_FETCHER_EMAIL=your.name@example.com
#   3. Interactive prompt   → shown automatically when running in a terminal
#
# Uncomment and set a real contact address:
# email = "your.name@example.com"

# ── Optional throttle & retry settings ───────────────────────────────────────
#
# The SEC specifies a maximum request rate of 10 requests/second (see link
# above). This library defaults to a conservative 2 req/s (500 ms delay,
# 1 concurrent request) to be a good citizen of the public service.
#
# Uncomment to override:
# max_concurrent = 1   # concurrent requests; lower = more polite to SEC servers
# min_delay_ms = 500   # ms between requests (500 ms = 2 req/s)
# max_retries = 3
# http_cache_storage_bin = "custom/path/to/cache.bin"
